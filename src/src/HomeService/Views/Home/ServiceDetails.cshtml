@model HomeService.Models.Service
@{
    ViewBag.Title = "Chi tiết dịch vụ";
    var categoryImages = new Dictionary<string, string>
    {
        { "Sửa điện", "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=1400&q=85" },
        { "Sửa nước", "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=1400&q=85" },
        { "Máy lạnh", "https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=1400&q=85" },
        { "Sơn nhà", "https://images.unsplash.com/photo-1562259929-b4e1fd3aef09?w=1400&q=85" },
        { "Chống thấm", "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1400&q=85" }
    };
    var imgUrl = categoryImages.TryGetValue(Model.Category?.Name ?? "", out var url) ? url : "https://images.unsplash.com/photo-1581858726788-75bc0f6a952d?w=1400&q=85";
}

<div class="page-content">
    <div class="breadcrumb-nav">
        <a href="@Url.Action("Index","Home")"><i class="bi bi-house"></i></a>
        <i class="bi bi-chevron-right separator"></i>
        <a href="@Url.Action("Services","Home")">Dịch vụ</a>
        <i class="bi bi-chevron-right separator"></i>
        <span class="current">@Model.Title</span>
    </div>

    <div class="row g-4">
        <!-- Left: Gallery & Info -->
        <div class="col-lg-8">
            <div class="detail-gallery mb-4">
                <img src="@imgUrl" alt="@Model.Title" />
            </div>

            <!-- Description -->
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">
                        <i class="bi bi-info-circle text-primary me-2"></i>Mô tả dịch vụ
                    </h4>
                    <p style="color:var(--gray-600);line-height:1.8;font-size:.95rem;">@Model.Description</p>
                    <p style="color:var(--gray-600);line-height:1.8;font-size:.95rem;">
                        Dịch vụ được thực hiện bởi đội ngũ thợ lành nghề với nhiều năm kinh nghiệm trong lĩnh vực @Model.Category?.Name.
                        Chúng tôi cam kết sử dụng vật tư chính hãng, quy trình chuyên nghiệp và bảo hành 12 tháng sau khi hoàn thành.
                    </p>

                    <!-- Includes -->
                    <div class="row g-3 mt-3">
                        @{
                            var includes = new[] {
                                (Icon: "bi-shield-check", Text: "Bảo hành 12 tháng", Color: "feature-icon-blue"),
                                (Icon: "bi-clock", Text: "Hoàn thành trong 1-2 ngày", Color: "feature-icon-green"),
                                (Icon: "bi-person-badge", Text: "Thợ được đào tạo bài bản", Color: "feature-icon-amber"),
                                (Icon: "bi-receipt", Text: "Hóa đơn VAT đầy đủ", Color: "feature-icon-purple")
                            };
                        }
                        @foreach(var inc in includes)
                        {
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2 p-3 bg-light-soft" style="border-radius:10px;">
                                    <div class="feature-icon-wrap @inc.Color" style="width:40px;height:40px;border-radius:8px;font-size:1rem;margin:0;">
                                        <i class="@inc.Icon"></i>
                                    </div>
                                    <span style="font-size:.85rem;font-weight:600;">@inc.Text</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Booking Sidebar -->
        <div class="col-lg-4">
            <div class="detail-sidebar-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="badge-status" style="background:rgba(37,99,235,.1);color:var(--primary);">
                        Còn trống
                    </span>
                    <span class="service-card-price" style="font-size:1.5rem;">
                        @Model.Price?.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN")) đ
                    </span>
                </div>

                <h5 style="font-size:1.05rem;margin-bottom:.5rem;">@Model.Title</h5>
                <p style="font-size:.82rem;color:var(--gray-500);margin-bottom:1.5rem;">
                    <i class="bi bi-tag me-1"></i>@Model.Category?.Name
                </p>

                <div class="mb-3 p-3 bg-light-soft" style="border-radius:12px;">
                    <ul class="detail-checklist">
                        <li><i class="bi bi-check-circle-fill"></i>Tư vấn miễn phí 100%</li>
                        <li><i class="bi bi-check-circle-fill"></i>Khảo sát tại nhà</li>
                        <li><i class="bi bi-check-circle-fill"></i>Báo giá chi tiết trước khi làm</li>
                        <li><i class="bi bi-check-circle-fill"></i>Vệ sinh sau khi hoàn thành</li>
                        <li><i class="bi bi-check-circle-fill"></i>Bảo hành 12 tháng</li>
                    </ul>
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    <a href="@Url.Action("Create","Booking", new { serviceId = Model.Id })" class="btn btn-accent w-100 py-2">
                        <i class="bi bi-calendar-plus me-2"></i>Đặt lịch ngay
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login","Account", new { returnUrl = Context.Request.Path })" class="btn btn-accent w-100 py-2">
                        <i class="bi bi-calendar-plus me-2"></i>Đặt lịch ngay
                    </a>
                    <p class="text-center" style="font-size:.78rem;color:var(--gray-400);margin-top:.75rem;">
                        Cần <a href="@Url.Action("Login","Account")">đăng nhập</a> để đặt lịch
                    </p>
                }

                <div class="mt-3 pt-3" style="border-top:1px solid var(--gray-200);">
                    <div class="d-flex align-items-center gap-2" style="font-size:.85rem;color:var(--gray-500);">
                        <i class="bi bi-telephone text-primary"></i>
                        Hotline: <strong style="color:var(--dark);">0123 456 789</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>