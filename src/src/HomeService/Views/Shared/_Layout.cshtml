<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DichVuSuaChuaNhaCua - @ViewBag.Title</title>
    <meta name="description" content="DichVuSuaChuaNhaCua - Dịch vụ sửa chữa nhà cửa chuyên nghiệp, nhanh chóng, bảo hành 12 tháng" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap&v=2" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/chatbot.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app-layout">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <span class="sidebar-brand-icon">
                    <i class="bi bi-house-heart-fill"></i>
                </span>
                <span class="sidebar-brand-text">
                    <span class="text-primary">DichVu</span><span class="text-dark">SuaChuaNhaCua</span>
                </span>
            </div>

            <nav class="sidebar-nav">
                <div class="sidebar-section">Menu</div>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   href="@Url.Action("Index", "Home")">
                    <i class="bi bi-house-door"></i>
                    <span>Trang chủ</span>
                </a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")"
                   href="@Url.Action("Services", "Home")">
                    <i class="bi bi-tools"></i>
                    <span>Dịch vụ</span>
                </a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")"
                   href="@Url.Action("Contact", "Home")">
                    <i class="bi bi-envelope"></i>
                    <span>Liên hệ</span>
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <div class="sidebar-divider"></div>
                    <div class="sidebar-section">Cá nhân</div>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")"
                       href="@Url.Action("MyBookings", "Booking")">
                        <i class="bi bi-clipboard2-check"></i>
                        <span>Đơn của tôi</span>
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                           href="@Url.Action("Index", "Admin")">
                            <i class="bi bi-speedometer2"></i>
                            <span>Quản trị</span>
                        </a>
                    }
                    <div class="sidebar-divider"></div>
                    <a class="sidebar-link danger" href="@Url.Action("Logout", "Account")">
                        <i class="bi bi-box-arrow-left"></i>
                        <span>Đăng xuất</span>
                    </a>
                }
                else
                {
                    <div class="sidebar-divider"></div>
                    <div class="sidebar-section">Tài khoản</div>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Login" ? "active" : "")"
                       href="@Url.Action("Login", "Account")">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Đăng nhập</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "active" : "")"
                       href="@Url.Action("Register", "Account")">
                        <i class="bi bi-person-plus"></i>
                        <span>Đăng ký</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer">
                <small>&copy; @DateTime.Now.Year DichVuSuaChuaNhaCua</small>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <header class="topbar">
                <button class="topbar-toggle" id="sidebarToggle" aria-label="Toggle menu">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <h1 class="topbar-title">@(ViewBag.Title ?? "DichVuSuaChuaNhaCua")</h1>
                <div class="topbar-actions">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="text-muted d-none d-md-inline" style="font-size:0.85rem;">
                            Xin chào, <strong class="text-dark">@(User.Identity.Name)</strong>
                        </span>
                    }
                </div>
            </header>

            @RenderBody()

            <footer class="app-footer">
                &copy; @DateTime.Now.Year DichVuSuaChuaNhaCua. Mọi quyền được bảo lưu.
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chatbot Widget -->
    <div class="chatbot-root">
        <button class="chatbot-toggle" id="chatbot-toggle" aria-label="Mở chat hỗ trợ">
            <i class="bi bi-chat-dots-fill"></i>
        </button>
        <div class="chatbot-window" id="chatbot-window">
            <div class="chatbot-header">
                <div class="chatbot-avatar">
                    <i class="bi bi-robot"></i>
                </div>
                <div class="chatbot-header-info">
                    <h4>Hỗ trợ trực tuyến</h4>
                    <p>● Trợ lý DichVuSuaChuaNhaCua</p>
                </div>
                <button class="chatbot-close" id="chatbot-close" aria-label="Đóng">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="chatbot-messages" id="chatbot-messages"></div>
            <div class="chatbot-quick-replies" id="chatbot-quick-replies"></div>
            <div class="chatbot-input">
                <input type="text" id="chatbot-input" placeholder="Nhập câu hỏi..." autocomplete="off" />
                <button id="chatbot-send" aria-label="Gửi" onclick="ChatBot.sendMessage()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>
    <script src="~/js/chatbot.js"></script>
    <script>
        (function () {
            var toggle = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('sidebar');
            var overlay = document.getElementById('sidebarOverlay');

            function openSidebar() {
                sidebar.classList.add('show');
                overlay.classList.add('show');
            }
            function closeSidebar() {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            }

            toggle.addEventListener('click', function () {
                sidebar.classList.contains('show') ? closeSidebar() : openSidebar();
            });
            overlay.addEventListener('click', closeSidebar);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>