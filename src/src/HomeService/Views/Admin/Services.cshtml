@model IEnumerable<HomeService.Models.Service>
@{
    ViewBag.Title = "Quản lý dịch vụ";
}

<div class="page-header admin">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h1><i class="bi bi-grid me-2"></i>Quản lý dịch vụ</h1>
            <p>@Model.Count() dịch vụ</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index","Admin")" class="btn btn-outline-light btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Quản lý đơn
            </a>
            <a href="@Url.Action("CreateService","Admin")" class="btn btn-light btn-sm text-dark">
                <i class="bi bi-plus-lg me-1"></i>Thêm dịch vụ
            </a>
        </div>
    </div>
</div>

<div class="page-content">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-grid"></i>
            </div>
            <h4>Chưa có dịch vụ nào</h4>
            <a href="@Url.Action("CreateService","Admin")" class="btn btn-primary mt-3">Thêm dịch vụ đầu tiên</a>
        </div>
    }
    else
    {
        var serviceImages = new[] {
            "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=100&q=60",
            "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=100&q=60",
            "https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=100&q=60",
            "https://images.unsplash.com/photo-1562259929-b4e1fd3aef09?w=100&q=60",
            "https://images.unsplash.com/photo-1581858726788-75bc0f6a952d?w=100&q=60",
            "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=100&q=60"
        };
        var si = 0;

        <div class="row g-4">
            @foreach(var s in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="service-card h-100">
                        <div class="service-card-img-wrap">
                            <img src="@serviceImages[si % serviceImages.Length]" class="service-card-img" alt="@s.Title" style="height:160px;" />
                        </div>
                        <div class="service-card-body">
                            <span class="category-badge mb-2 d-inline-block">@s.Category?.Name</span>
                            <h5 class="service-card-title">@s.Title</h5>
                            <p class="service-card-desc">@s.Description</p>
                            <div class="service-card-footer">
                                <div class="service-card-price">@s.Price?.ToString("N0") đ</div>
                                <div class="actions">
                                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("EditService","Admin", new { id = s.Id })">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-sm btn-outline-danger" href="@Url.Action("DeleteService","Admin", new { id = s.Id })"
                                       onclick="return confirm('Xoá dịch vụ này?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                si++;
            }
        </div>
    }
</div>