@{
    ViewBag.Title = "Đăng nhập";
}

<div class="page-content" style="background:linear-gradient(135deg, var(--gray-50) 0%, #eef2ff 100%);">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">
            <div class="auth-card">
                <div class="row g-0">
                    <div class="col-md-5 d-none d-md-block">
                        <div class="auth-card-img h-100">
                            <div class="auth-card-icon">
                                <i class="bi bi-house-heart-fill"></i>
                            </div>
                            <h3>Chào mừng bạn!</h3>
                            <p>Đăng nhập để quản lý đơn hàng và đặt dịch vụ nhanh chóng.</p>
                            <div class="mt-4">
                                <div class="d-flex justify-content-center gap-4 fs-3">
                                    <i class="bi bi-shield-check opacity-50"></i>
                                    <i class="bi bi-lightning-charge opacity-50"></i>
                                    <i class="bi bi-star opacity-50"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="auth-card-body">
                            <div class="text-center mb-4">
                                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                                     style="width:52px;height:52px;background:rgba(37,99,235,.1);">
                                    <i class="bi bi-person-fill text-primary fs-4"></i>
                                </div>
                                <h2>Đăng nhập</h2>
                                <p class="subtitle">Chào mừng bạn quay trở lại</p>
                            </div>

                            @if (ViewData.ModelState.ErrorCount > 0)
                            {
                                <div class="alert alert-danger" role="alert">
                                    <i class="bi bi-exclamation-circle"></i>
                                    <div>
                                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                        {
                                            <div>@error.ErrorMessage</div>
                                        }
                                    </div>
                                </div>
                            }

                            <form method="post">
                                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                                <div class="mb-3">
                                    <label class="form-label">Tên đăng nhập</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                                        <input type="text" name="username" class="form-control" placeholder="Nhập tên đăng nhập" required autofocus />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                        <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required />
                                    </div>
                                </div>

                                <button class="btn btn-primary w-100 py-2 mt-2" type="submit">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                                </button>
                            </form>

                            <div class="auth-card-footer">
                                <p class="mb-0">
                                    Chưa có tài khoản?
                                    <a href="@Url.Action("Register","Account")">Đăng ký ngay</a>
                                </p>
                            </div>

                            <div class="mt-3 p-3 bg-light-soft" style="border-radius:10px;font-size:.78rem;">
                                <strong>Tài khoản demo:</strong> admin / admin123
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>