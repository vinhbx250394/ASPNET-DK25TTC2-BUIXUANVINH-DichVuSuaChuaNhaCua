@model HomeService.Models.Service
@{
    ViewBag.Title = "Thêm dịch vụ";
}

<div class="page-content">
    <div class="breadcrumb-nav">
        <a href="@Url.Action("Index","Admin")"><i class="bi bi-speedometer2"></i></a>
        <i class="bi bi-chevron-right separator"></i>
        <a href="@Url.Action("Services","Admin")">Quản lý dịch vụ</a>
        <i class="bi bi-chevron-right separator"></i>
        <span class="current">Thêm dịch vụ</span>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body" style="padding:2rem;">
                    <h4 class="card-title mb-4">
                        <i class="bi bi-plus-circle text-primary me-2"></i>Thêm dịch vụ mới
                    </h4>

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-circle"></i>
                            <div>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            </div>
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tiêu đề dịch vụ *</label>
                            <input asp-for="Title" class="form-control" placeholder="VD: Sửa điện cơ bản" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Danh mục *</label>
                                <select asp-for="CategoryId" class="form-select" required>
                                    <option value="">-- Chọn danh mục --</option>
                                    @foreach(var c in ViewBag.Categories as List<HomeService.Models.Category>)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Giá (VNĐ) *</label>
                                <input asp-for="Price" class="form-control" placeholder="VD: 200000" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Mô tả chi tiết dịch vụ..."></textarea>
                        </div>

                        <div class="d-flex gap-3">
                            <a href="@Url.Action("Services","Admin")" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                            <button class="btn btn-success flex-grow-1" type="submit">
                                <i class="bi bi-check-lg me-2"></i>Lưu dịch vụ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>